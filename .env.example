# ══════════════════════════════════════════════════════════════════════════════
# Archivo raíz .env — usado por docker-compose para sustituir ${VAR}
# Copia este archivo como .env y rellena los valores marcados con REEMPLAZA_...
# ══════════════════════════════════════════════════════════════════════════════

# ── Autenticación (better-auth) ───────────────────────────────────────────────
# Secret aleatorio para firmar sesiones — genera uno con:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=REEMPLAZA_CON_UN_SECRET_DE_32_CARACTERES
POSTGRES_PASSWORD=REEMPLAZA_CON_UN_PASSWORD_LARGO
INGEST_SHARED_SECRET=REEMPLAZA_CON_OTRO_SECRET_LARGO

# ── Control remoto de sensores (WS) ───────────────────────────────────────────
# Secreto dashboard BFF -> ingest-api para /sensors/:id/commands (admin).
# Genera uno con: openssl rand -hex 32
CONTROL_API_SECRET=REEMPLAZA_CON_OTRO_SECRET_LARGO
# Pepper para hashear las credenciales de control WebSocket por sensor.
# OBLIGATORIO: sin este valor el ingest-api no arranca (falla cerrado a
# propósito — ver apps/ingest-api/src/modules/sensor-control). Nunca
# reutilizar INGEST_SHARED_SECRET ni CONTROL_API_SECRET. Rotarlo invalida
# TODAS las credenciales de control ya emitidas.
# Genera uno con: openssl rand -hex 32
SENSOR_CONTROL_CREDENTIAL_PEPPER=REEMPLAZA_CON_OTRO_SECRET_LARGO

# Read replica (streaming standby). El primario crea este rol en su primer init
# y el standby lo usa para clonar y replicar. Si cambias esto DESPUÉS del primer
# arranque, debes recrear el volumen del primario o crear el rol a mano.
#   openssl rand -base64 32
REPLICATION_USER=replicator
REPLICATION_PASSWORD=REEMPLAZA_CON_UN_PASSWORD_DE_REPLICACION
REPLICATION_SLOT=honeypot_replica_slot

# URL pública del dashboard (debe coincidir exactamente con el origen del navegador)
# - Single-host por túnel normal:  http://localhost:4000
# - Single-host por túnel alterno: http://localhost:4400
# - No la apuntes a localhost:4000 si en realidad estás entrando por localhost:4400,
#   porque better-auth responderá "Invalid origin" en setup/login.
BETTER_AUTH_URL=http://localhost:4000

# ── Infraestructura del honeypot (opcional — pre-carga la página Settings) ───
HONEYPOT_IP=
HONEYPOT_SSH_PORT=22
HONEYPOT_INGEST_PORT=8022

# ── Zona horaria del dashboard (opcional — se puede cambiar en Settings) ──────
DASHBOARD_TIMEZONE=UTC

# ── Alertas Discord (opcional) ────────────────────────────────────────────────
# Webhook URL del canal donde quieres recibir alertas
# Crea uno en: Discord → canal → Editar → Integraciones → Webhooks
DISCORD_WEBHOOK_URL=

# ── GeoLite2 (geoip-lite) — refresco semanal automático ───────────────────────
# License key gratuita de MaxMind, usada por el contenedor geoip-updater para
# descargar la base GeoLite2 (país/ciudad) más reciente cada 7 días.
# Sacala en: https://www.maxmind.com/en/geolite2/signup → confirma el email →
# My Account → Manage License Keys → Generate new license key
# (elegí "No" en "¿vas a usar GeoIP Legacy?")
MAXMIND_LICENSE_KEY=REEMPLAZA_CON_TU_LICENSE_KEY_DE_MAXMIND

# ── OVA de sensores ───────────────────────────────────────────────────────────
# URL del asset honeypot-sensor-disk.vmdk en GitHub Releases
# El dashboard lo descarga una vez y cachea para generar OVAs por cliente
# Ejemplo: https://github.com/org/repo/releases/download/sensor-ova-v1.0.0/honeypot-sensor-disk.vmdk
BASE_VMDK_URL=
# URL pública del ingest-api que el sensor VM usa para conectarse desde fuera del servidor.
# En single-host: http://<ip-publica-contabo>:3000  (puerto 3000 debe estar abierto en firewall)
# En multi-host con dominio: dejar vacío (usa NEXT_PUBLIC_API_URL automáticamente)
SENSOR_INGEST_URL=

# Solo para el despliegue separado del nodo honeypot (`docker-compose.prod.honeypot.yml`)
# URL privada/VPN del ingest API central, por ejemplo: http://100.64.0.10:3000
INGEST_API_URL=

# Opcional: asigna este stack completo a un cliente
CLIENT_SLUG=
CLIENT_NAME=

# Credencial de control WebSocket del sensor Cowrie (opcional). Se emite con
# POST /sensors/:sensorId/control-credential (admin, ver sensor-control.controller.ts)
# usando el mismo SENSOR_ID que SENSOR_ID_SSH — el secreto solo se muestra una
# vez en esa respuesta. Sin este valor, el beacon corre igual pero sin plano
# de control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_SSH=

# Credencial de control WebSocket del sensor Web Honeypot (opcional). Se emite
# con POST /sensors/:sensorId/control-credential (admin) usando el mismo
# SENSOR_ID que SENSOR_ID_HTTP — el secreto solo se muestra una vez en esa
# respuesta. Sin este valor, web-honeypot-beacon corre igual pero sin plano
# de control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_HTTP=

# Credencial de control WebSocket del sensor Port Honeypot (opcional). Se emite
# con POST /sensors/:sensorId/control-credential (admin) usando el mismo
# SENSOR_ID que SENSOR_ID_PORT — el secreto solo se muestra una vez en esa
# respuesta. Sin este valor, port-honeypot corre igual pero sin plano de
# control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_PORT=

# Credencial de control WebSocket del sensor SMB Honeypot (opcional). Se emite
# con POST /sensors/:sensorId/control-credential (admin) usando el mismo
# SENSOR_ID que SENSOR_ID_SMB — el secreto solo se muestra una vez en esa
# respuesta. Sin este valor, smb-honeypot corre igual pero sin plano de
# control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_SMB=

# Credencial de control WebSocket del sensor FTP Honeypot (opcional). Se emite
# con POST /sensors/:sensorId/control-credential (admin) usando el mismo
# SENSOR_ID que SENSOR_ID_FTP — el secreto solo se muestra una vez en esa
# respuesta. Sin este valor, ftp-honeypot corre igual pero sin plano de
# control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_FTP=

# Credencial de control WebSocket del sensor MySQL Honeypot (opcional). Se
# emite con POST /sensors/:sensorId/control-credential (admin) usando el
# mismo SENSOR_ID que SENSOR_ID_MYSQL — el secreto solo se muestra una vez en
# esa respuesta. Sin este valor, mysql-honeypot corre igual pero sin plano de
# control remoto (status.get, etc).
SENSOR_CONTROL_SECRET_MYSQL=

# Solo para el despliegue app/proxy (`docker-compose.prod.app.yml`)
# Dominio publico del dashboard, por ejemplo: soc.midominio.com
DASHBOARD_DOMAIN=
# Subdominio publico del API si usas uno separado, por ejemplo: api.midominio.com
API_DOMAIN=
# URL publica del API para el dashboard cuando no quieras usar el default del compose
NEXT_PUBLIC_API_URL=

# GID del grupo 'docker' del host — para que el ingest-api (no-root) pueda leer
# /var/run/docker.sock y mostrar el monitoreo de contenedores (CPU/RAM).
# Default 110. Auto-detecta y fija en .env con:
#   echo "DOCKER_GID=$(stat -c '%g' /var/run/docker.sock)" >> .env
DOCKER_GID=110
