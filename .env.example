# ══════════════════════════════════════════════════════════════════════════════
# Archivo raíz .env — usado por docker-compose para sustituir ${VAR}
# Copia este archivo como .env y rellena los valores marcados con REEMPLAZA_...
# ══════════════════════════════════════════════════════════════════════════════

# ── Autenticación (better-auth) ───────────────────────────────────────────────
# Secret aleatorio para firmar sesiones — genera uno con:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=REEMPLAZA_CON_UN_SECRET_DE_32_CARACTERES
POSTGRES_PASSWORD=REEMPLAZA_CON_UN_PASSWORD_LARGO
INGEST_SHARED_SECRET=REEMPLAZA_CON_OTRO_SECRET_LARGO

# URL pública del dashboard (debe coincidir exactamente con el origen del navegador)
# - Single-host por túnel normal:  http://localhost:4000
# - Single-host por túnel alterno: http://localhost:4400
# - No la apuntes a localhost:4000 si en realidad estás entrando por localhost:4400,
#   porque better-auth responderá "Invalid origin" en setup/login.
BETTER_AUTH_URL=http://localhost:4000

# ── Infraestructura del honeypot (opcional — pre-carga la página Settings) ───
HONEYPOT_IP=
HONEYPOT_SSH_PORT=22
HONEYPOT_INGEST_PORT=8022

# ── Zona horaria del dashboard (opcional — se puede cambiar en Settings) ──────
DASHBOARD_TIMEZONE=UTC
