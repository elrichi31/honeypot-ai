# Local multi-VM lab - SSH + Web sensor VM
# Copy to .env on the sensor VM and adjust the IPs for that VM.

# Replace with the private IP of the central/core VM.
INGEST_API_URL=http://192.168.56.10:3000
INGEST_SHARED_SECRET=replace_with_the_same_shared_secret_as_the_core

# Optional: set the private IP of this sensor VM so the dashboard shows it directly.
HONEYPOT_IP=192.168.56.11

SENSOR_ID_SSH=cowrie-ssh-local-01
SENSOR_NAME_SSH=SSH Honeypot (Cowrie) - Local VM

SENSOR_ID_HTTP=web-local-01
SENSOR_NAME_HTTP=Web Honeypot - Local VM
