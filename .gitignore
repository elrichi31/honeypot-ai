# Dependencies
node_modules/

# Build output
dist/

# Environment files
.env
.env.local
.env.*.local

# Prisma generated client (regenerated on install)
apps/ingest-api/node_modules/

# Cowrie live data (runtime logs, not for version control)
cowrie.json
cowrie-live.json
cowrie-data/

# Temp build artifacts
.tmp/

# OS
.DS_Store
Thumbs.db
__pycache__/
*.py[cod]

# Editor
.vscode/
.idea/
*.swp
*.swo
# Dashboard runtime data (API keys, AI cache, enrichment cache)
apps/dashboard/data/

# Claude Code local settings (everything under .claude/ except the skills
# directory, which is tracked so skills travel with the repo)
.claude/*
!.claude/skills/
.mcp.json

# .agents/ is the symlink target cache for .claude/skills/ — regenerable,
# and the symlinks themselves were dereferenced into real copies under
# .claude/skills/ before committing (they were absolute-path, machine-specific).
.agents/

# DB dumps / restore test artifacts
*.dump
restore*.log
