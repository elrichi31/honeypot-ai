{
  "name": "ingest-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run db:generate && tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.3.0",
    "@prisma/client": "^6.6.0",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.1.0",
    "geoip-lite": "^2.0.1",
    "ioredis": "^5.11.0",
    "kafkajs": "^2.2.4",
    "node-cron": "^3.0.3",
    "zod": "^3.24.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^22.15.2",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2",
    "ws": "^8.21.0"
  }
}
