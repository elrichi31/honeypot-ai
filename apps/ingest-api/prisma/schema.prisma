generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Session {
  id              String   @id @default(uuid())
  cowrieSessionId String   @unique @map("cowrie_session_id")
  srcIp           String   @map("src_ip")
  protocol        String
  sensorId        String?  @map("sensor_id")
  username        String?
  password        String?
  loginSuccess    Boolean? @map("login_success")
  hassh           String?
  clientVersion   String?  @map("client_version")
  startedAt       DateTime @map("started_at")
  endedAt         DateTime? @map("ended_at")
  sessionType     String   @default("unknown") @map("session_type")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  events Event[]

  @@index([srcIp])
  @@index([srcIp, startedAt(sort: Desc)])
  @@index([sensorId])
  @@index([startedAt(sort: Desc)])
  @@index([loginSuccess, startedAt(sort: Desc)])
  @@index([sessionType])
  @@index([sessionType, startedAt(sort: Desc)])
  @@index([startedAt, endedAt])
  @@map("sessions")
}

model Event {
  id             String   @id @default(uuid())
  sessionId      String   @map("session_id")
  eventType      String   @map("event_type")
  eventTs        DateTime @map("event_ts")
  srcIp          String   @map("src_ip")
  message        String?
  command        String?
  username       String?
  password       String?
  success        Boolean?
  rawJson        Json     @map("raw_json")
  normalizedJson Json     @map("normalized_json")
  createdAt      DateTime @default(now()) @map("created_at")

  cowrieEventId  String   @map("cowrie_event_id")
  cowrieTs        String   @map("cowrie_ts")

  session Session @relation(fields: [sessionId], references: [id])

  @@unique([cowrieEventId, cowrieTs], name: "uq_cowrie_event")
  @@index([sessionId])
  @@index([eventType])
  @@index([eventTs(sort: Desc)])
  @@index([srcIp, eventTs(sort: Desc)])
  @@index([eventType, eventTs(sort: Desc)])
  @@index([sessionId, eventType])
  @@index([eventType, success])
  @@map("events")
}

model ProtocolHit {
  id        String   @id @default(uuid())
  eventId   String   @unique @map("event_id")
  protocol  String   // ftp | mysql | port-scan
  srcIp     String   @map("src_ip")
  srcPort   Int?     @map("src_port")
  dstPort   Int      @map("dst_port")
  eventType String   @map("event_type") // connect | auth | command
  username  String?
  password  String?
  sensorId  String?  @map("sensor_id")
  data      Json     @default("{}")
  timestamp DateTime
  createdAt DateTime @default(now()) @map("created_at")

  @@index([srcIp])
  @@index([protocol])
  @@index([dstPort])
  // Per-sensor + time range — drives the per-client activity chart and threats
  // ranking. Composite (sensor_id, timestamp) supersedes the standalone
  // sensor_id index: Seq Scan (~1.5s) -> Index Only Scan (~0.17s).
  @@index([sensorId, timestamp])
  @@index([timestamp(sort: Desc)])
  @@index([protocol, timestamp(sort: Desc)])
  @@index([srcIp, protocol, timestamp(sort: Desc)])
  // Covering index for the dashboard overview per-protocol aggregate — turns a
  // full Seq Scan (~2.1s) into an Index Only Scan (~0.6s) on 1M+ rows.
  @@index([timestamp, protocol, eventType, srcIp], map: "protocol_hits_overview_covering_idx")
  @@map("protocol_hits")
}

model MalwareSample {
  id          String   @id @default(uuid())
  md5         String   @unique
  fileType    String   @default("Binary") @map("file_type")
  size        BigInt   @default(0)
  source      String   // dionaea | cowrie | ftp
  sourceUrl   String?  @map("source_url")
  sourceName  String?  @map("source_name")
  srcIp       String?  @map("src_ip")
  srcPort     Int?     @map("src_port")
  dstPort     Int?     @map("dst_port")
  sensorId    String?  @map("sensor_id")
  capturedAt  DateTime @map("captured_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([srcIp])
  @@index([capturedAt(sort: Desc)])
  @@index([source])
  @@index([sensorId])
  @@map("malware_samples")
}

model Application {
  id        String   @id
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  sensors Sensor[]

  @@map("applications")
}

model Sensor {
  id            String   @id @default(cuid())
  sensorId      String   @unique @map("sensor_id")
  clientId      String?  @map("client_id")
  applicationId String?  @map("application_id")
  ownerType     String   @default("application") @map("owner_type")
  name          String
  protocol      String
  realProtocol  String?  @map("real_protocol")
  ip            String
  version       String   @default("")
  ports         Json     @default("[]")
  probePorts    Json     @default("[]") @map("probe_ports")
  probeHost     String   @default("") @map("probe_host")
  lastSeen      DateTime @map("last_seen")
  createdAt     DateTime @default(now()) @map("created_at")

  client      Client?      @relation(fields: [clientId], references: [id])
  application Application? @relation(fields: [applicationId], references: [id])

  @@index([clientId])
  @@index([ownerType])
  @@index([lastSeen(sort: Desc)])
  @@map("sensors")
}

model Client {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  code                String   @default("")
  description         String   @default("")
  forwardUrl          String   @default("") @map("forward_url")
  crowdstrikeHecUrl   String   @default("") @map("crowdstrike_hec_url")
  crowdstrikeApiKey   String   @default("") @map("crowdstrike_api_key")
  createdAt           DateTime @default(now()) @map("created_at")

  sensors          Sensor[]
  provisionTokens  SensorProvisionToken[]

  @@index([code])
  @@index([name])
  @@map("clients")
}

model ApiDefenseEvent {
  id         String   @id @default(uuid())
  srcIp      String   @map("src_ip")
  method     String
  path       String
  userAgent  String   @default("") @map("user_agent")
  attackType String   @map("attack_type")
  details    Json     @default("{}")
  statusCode Int?     @map("status_code")
  timestamp  DateTime @default(now())

  @@index([srcIp])
  @@index([attackType])
  @@index([timestamp(sort: Desc)])
  @@index([srcIp, timestamp(sort: Desc)])
  @@map("api_defense_events")
}

model SensorProvisionToken {
  id        String    @id @default(cuid())
  token     String    @unique
  clientId  String?   @map("client_id")
  services  String    @default("ssh,http,ftp,mysql,port")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([token])
  @@map("sensor_provision_tokens")
}

model BlockedIp {
  id          String   @id @default(uuid())
  ip          String   @unique
  reason      String   @default("manual")
  autoBlocked Boolean  @default(false) @map("auto_blocked")
  blockedAt   DateTime @default(now()) @map("blocked_at")

  @@index([ip])
  @@map("blocked_ips")
}

model RetentionSettings {
  id            String   @id
  tableName     String   @unique @map("table_name")
  label         String
  retentionDays Int      @default(90) @map("retention_days")
  enabled       Boolean  @default(true)
  updatedAt     DateTime @default(now()) @map("updated_at")

  @@map("retention_settings")
}

model RetentionRun {
  id          String    @id @default(uuid())
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  rowsDeleted Int       @default(0) @map("rows_deleted")
  perTable    Json      @default("{}") @map("per_table")
  ok          Boolean   @default(true)
  error       String?

  @@index([startedAt(sort: Desc)])
  @@map("retention_runs")
}

model DefenseAllowlist {
  id        String   @id @default(uuid())
  entry     String   @unique  // IP or CIDR, e.g. "1.2.3.4" or "10.0.0.0/8"
  label     String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("defense_allowlist")
}

model ContainerSnapshot {
  id          Int      @id @default(autoincrement())
  container   String
  cpuPct      Float    @map("cpu_pct")
  memMb       Float    @map("mem_mb")
  sampledAt   DateTime @default(now()) @map("sampled_at")

  @@index([sampledAt(sort: Desc)])
  @@index([container, sampledAt(sort: Desc)])
  @@map("container_snapshots")
}

model MonitoringSnapshot {
  id            Int      @id @default(autoincrement())
  cpuLoad1m     Float    @map("cpu_load_1m")
  cpuLoad5m     Float    @map("cpu_load_5m")
  ramUsedKb     Int      @map("ram_used_kb")
  ramTotalKb    Int      @map("ram_total_kb")
  ramPct        Float    @map("ram_pct")
  sampledAt     DateTime @default(now()) @map("sampled_at")

  @@index([sampledAt(sort: Desc)])
  @@map("monitoring_snapshots")
}

model ThreatAlertCooldown {
  key       String   @id
  expiresAt DateTime @map("expires_at")

  @@map("threat_alert_cooldown")
}

// Permanent daily rollups — small summaries that survive raw-data retention.
model DailyAttackerStat {
  day             DateTime @db.Date
  srcIp           String   @map("src_ip")
  events          BigInt   @default(0)
  authAttempts    BigInt   @default(0) @map("auth_attempts")
  loginSuccesses  BigInt   @default(0) @map("login_successes")
  protocolHits    BigInt   @default(0) @map("protocol_hits")
  webHits         BigInt   @default(0) @map("web_hits")
  sessions        BigInt   @default(0)
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@id([day, srcIp])
  @@index([day(sort: Desc)])
  @@index([srcIp])
  @@map("daily_attacker_stats")
}

model DailySummary {
  day             DateTime @id @db.Date
  sshEvents       BigInt   @default(0) @map("ssh_events")
  webHits         BigInt   @default(0) @map("web_hits")
  protocolHits    BigInt   @default(0) @map("protocol_hits")
  sessions        BigInt   @default(0)
  uniqueIps       BigInt   @default(0) @map("unique_ips")
  loginSuccesses  BigInt   @default(0) @map("login_successes")
  suricataAlerts  BigInt   @default(0) @map("suricata_alerts")
  updatedAt       DateTime @default(now()) @map("updated_at")

  @@index([day(sort: Desc)])
  @@map("daily_summary")
}

model DailyCredentialStat {
  day        DateTime @db.Date
  username   String   @default("")
  password   String   @default("")
  attempts   BigInt   @default(0)
  successes  BigInt   @default(0)
  uniqueIps  BigInt   @default(0) @map("unique_ips")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@id([day, username, password])
  @@index([day(sort: Desc)])
  @@map("daily_credential_stats")
}

model DailyCommandStat {
  day        DateTime @db.Date
  command    String
  count      BigInt   @default(0)
  uniqueIps  BigInt   @default(0) @map("unique_ips")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@id([day, command])
  @@index([day(sort: Desc)])
  @@map("daily_command_stats")
}

// Persisted threat alerts (the ones also pushed to Discord), so the dashboard
// can list them and show an unread count. Spans all clients/sensors.
model Alert {
  id          String   @id @default(uuid())
  alertKey    String   @map("alert_key")
  level       String   @default("high") // critical | high | info
  title       String
  description String   @default("")
  fields      Json     @default("[]")
  srcIp       String?  @map("src_ip")
  sensorId    String?  @map("sensor_id")
  clientId    String?  @map("client_id")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt(sort: Desc)])
  @@index([readAt])
  @@index([level])
  @@index([clientId])
  @@index([clientId, createdAt(sort: Desc)])
  @@map("alerts")
}

model SuricataAlert {
  id          String   @id @default(uuid())
  sensorId    String   @default("") @map("sensor_id")
  timestamp   DateTime
  srcIp       String   @default("") @map("src_ip")
  srcPort     Int?     @map("src_port")
  destIp      String   @default("") @map("dest_ip")
  destPort    Int?     @map("dest_port")
  proto       String   @default("")
  action      String   @default("allowed")
  signatureId Int      @default(0) @map("signature_id")
  signature   String   @default("")
  category    String   @default("")
  severity    Int      @default(3)
  flowId      BigInt?  @map("flow_id")
  inIface     String?  @map("in_iface")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([srcIp])
  @@index([severity])
  @@index([signatureId])
  @@index([timestamp(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([srcIp, timestamp(sort: Desc)])
  @@map("suricata_alerts")
}

model SensorConfig {
  sensorId   String   @id @map("sensor_id")
  config     Json     @default("{}")
  configHash String   @default("") @map("config_hash")
  updatedAt  DateTime @default(now()) @map("updated_at")

  @@map("sensor_configs")
}

model WebHit {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  srcIp       String   @map("src_ip")
  sensorId    String?  @map("sensor_id")
  method      String
  path        String
  query       String   @default("")
  userAgent   String   @default("") @map("user_agent")
  headers     Json
  body        String   @default("")
  attackType      String   @map("attack_type")
  canaryTriggered Boolean  @default(false) @map("canary_triggered")
  timestamp       DateTime
  createdAt       DateTime @default(now()) @map("created_at")

  // Session tracking — populated by the honeypot sensor
  sessionHits       Int?     @map("session_hits")
  sessionElapsedS   Float?   @map("session_elapsed_s")
  pathsVisited      String[] @map("paths_visited")
  attackChain       String[] @map("attack_chain")
  isChainAttack     Boolean? @map("is_chain_attack")
  clientFingerprint String?  @map("client_fingerprint")
  canaryTokenType   String?  @map("canary_token_type")
  referer           String?
  httpVersion       String?  @map("http_version")

  @@index([srcIp])
  @@index([sensorId])
  @@index([attackType])
  @@index([timestamp])
  @@index([srcIp, timestamp(sort: Desc)])
  @@index([attackType, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc), srcIp, attackType])
  @@index([path])
  @@index([clientFingerprint])
  @@index([isChainAttack, timestamp(sort: Desc)])
  @@map("web_hits")
}
