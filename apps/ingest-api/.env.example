# ── Base de datos ─────────────────────────────────────────────────────────────
# Local: postgres corre en el host (docker compose up postgres)
# connection_limit: pool de conexiones Prisma (default 10, sube a 50 en producción)
DATABASE_URL=postgresql://honeypot:honeypot@localhost:5432/honeypot?connection_limit=50

# ── Autenticación de sensores ─────────────────────────────────────────────────
# Secreto compartido entre ingest-api y todos los sensores.
# Debe coincidir exactamente con INGEST_SHARED_SECRET de los sensores y el dashboard.
# Genera uno con: openssl rand -hex 32
# IMPORTANTE: si no se define, el ingest-api rechaza TODOS los requests de sensores.
INGEST_SHARED_SECRET=REEMPLAZA_CON_UN_SECRET_LARGO

# Secreto exclusivo dashboard BFF -> ingest-api para comandos administrativos.
# No reutilizar INGEST_SHARED_SECRET: los sensores tambien lo conocen.
# Sin este valor, las rutas /sensors/:sensorId/commands rechazan todo.
CONTROL_API_SECRET=REEMPLAZA_CON_OTRO_SECRET_LARGO

# Pepper para hashear las credenciales de control WebSocket por sensor
# (sensor_control_credentials.secret_hash). Nunca reutilizar el valor de
# INGEST_SHARED_SECRET ni CONTROL_API_SECRET. Rotar esto invalida TODAS las
# credenciales emitidas (cada sensor necesitaria re-provisionarse) — tratar
# la rotacion como una operacion deliberada, no rutinaria.
# Genera uno con: openssl rand -hex 32
SENSOR_CONTROL_CREDENTIAL_PEPPER=REEMPLAZA_CON_OTRO_SECRET_LARGO

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
