# ── Ingest API ────────────────────────────────────────────────────────────────
# URL pública que usa el navegador para llamar al ingest-api
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL interna que usa el servidor Next.js para llamar al ingest-api
# - Local dev → localhost:3000  (ingest-api corre en Docker con el puerto mapeado)
# - Docker     → http://ingest-api:3000  (lo sobreescribe docker-compose)
INTERNAL_API_URL=http://localhost:3000

# ── Base de datos ─────────────────────────────────────────────────────────────
# Misma BD que ingest-api — auth, AI cache y enrichment cache viven aquí
DATABASE_URL=postgresql://honeypot:honeypot@localhost:5432/honeypot_prod

# ── Autenticación (better-auth) ───────────────────────────────────────────────
# Secret aleatorio para firmar sesiones — genera uno con:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=REEMPLAZA_CON_UN_SECRET_DE_32_CARACTERES

# URL base del dashboard (usada por better-auth para CSRF y cookies)
# - Local dev → puerto 3001 porque el 3000 lo ocupa ingest-api
# - Docker    → puerto 4000
# - Si accedes por un túnel SSH en otro puerto local, debe coincidir exactamente
#   con ese origen, por ejemplo http://localhost:4400
BETTER_AUTH_URL=http://localhost:3001

# ── Infraestructura del honeypot (opcional — pre-carga la página Settings) ───
HONEYPOT_IP=
HONEYPOT_SSH_PORT=22
HONEYPOT_INGEST_PORT=8022

# ── Zona horaria del dashboard (opcional — se puede cambiar en Settings) ──────
# Usa nombres IANA: America/Bogota, America/Lima, Europe/Madrid, UTC, etc.
DASHBOARD_TIMEZONE=UTC
