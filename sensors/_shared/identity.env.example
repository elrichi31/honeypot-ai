# Unified sensor identity — copy to .env or inject via compose environment:.
# All honeypot sensors on the same host must share these values so an attacker
# pivoting across ports sees a single coherent machine identity.
#
# Usage: set these env vars in docker-compose (environment: section) for every
# sensor service. The values here are the defaults used when the env var is absent.

# ── Machine identity ──────────────────────────────────────────────────────────
# Short hostname shown in banners, SMB server name, shell prompts, etc.
SENSOR_HOSTNAME=web-prod-01

# Fully-qualified domain name used in database connection strings, VPN configs, etc.
SENSOR_DOMAIN=corp.internal

# OS label for SMB and other protocol OS fields.
# Must match the SMB dialect advertised (SMB 2.0.2 → Windows Server 2008 R2).
SENSOR_OS=Windows Server 2008 R2 Standard

# Windows domain / workgroup name for SMB.
SENSOR_WIN_DOMAIN=CORP

# ── FTP identity ──────────────────────────────────────────────────────────────
FTP_BANNER=220 (vsFTPd 3.0.5)\r\n

# ── SMB identity ──────────────────────────────────────────────────────────────
# SMB_SERVER_NAME should equal SENSOR_HOSTNAME (set in compose to keep DRY).
SMB_SERVER_NAME=web-prod-01
SMB_SERVER_OS=Windows Server 2008 R2 Standard
SMB_SERVER_DOMAIN=CORP
SMB_SHARE_COMMENT=Corp Remote Admin

# ── Cowrie (SSH) identity ─────────────────────────────────────────────────────
# cowrie.cfg [honeypot] hostname = web-prod-01
# Must be updated manually in sensors/cowrie/cowrie.cfg to match SENSOR_HOSTNAME.

# ── Port-honeypot internal panels ─────────────────────────────────────────────
# Displayed in the fake "Operations Dashboard" on port 8888/9090.
PORT_PANEL_TITLE=Operations Dashboard
PORT_PANEL_ORG=Corp Internal Dashboard
