# Local multi-VM lab - central/core VM
# Copy to .env on the central VM and adjust the IPs for that VM.

POSTGRES_PASSWORD=replace_with_a_long_password
INGEST_SHARED_SECRET=replace_with_a_shared_secret_for_all_sensors
BETTER_AUTH_SECRET=replace_with_a_random_secret

# Replace with the private IP of the central VM.
NEXT_PUBLIC_API_URL=http://192.168.56.10:3000
BETTER_AUTH_URL=http://192.168.56.10:4000

DASHBOARD_TIMEZONE=America/Guayaquil
DISCORD_WEBHOOK_URL=

# Optional UI prefill values
HONEYPOT_IP=
HONEYPOT_SSH_PORT=22
HONEYPOT_INGEST_PORT=3000
